# Copy to .env.local for local dev
# Bun auto-loads .env.local
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ALLOWED_USERS=user_id_1,user_id_2
COMPOSIO_API_KEY=your_composio_api_key

# AI provider — any OpenAI-compatible endpoint
AI_API_KEY=your_api_key
# AI_BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o-mini

# Examples:
# OpenAI:      AI_BASE_URL=https://api.openai.com/v1          MODEL=gpt-4o
# Groq:        AI_BASE_URL=https://api.groq.com/openai/v1     MODEL=llama-3.3-70b-versatile
# OpenRouter:  AI_BASE_URL=https://openrouter.ai/api/v1       MODEL=anthropic/claude-sonnet-4-5

LOG_LEVEL=INFO
AGENT_MAX_STEPS=25
MAX_TOKENS=8192
