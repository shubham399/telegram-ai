# Copy to .env.local for local dev
# Bun auto-loads .env.local

# Required
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_ALLOWED_USERS=user_id_1,user_id_2
COMPOSIO_API_KEY=your_composio_api_key
AI_API_KEY=your_api_key

# Optional
# AI_BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o-mini
# LOG_LEVEL=INFO
# AGENT_MAX_STEPS=25

# Max chars of a tool result kept in the conversation sent to the model.
# Large tool results (e.g. Gmail fetch of many messages) can blow past the
# model's context window and cause a negative max_tokens error — this caps it.
MAX_TOOL_RESULT_CHARS=16000
