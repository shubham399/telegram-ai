{
  "name": "telegram-ai",
  "version": "0.1.0",
  "description": "Telegram bot — whitelisted messages → AI → Composio tool execution",
  "type": "module",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": "",
  "keywords": ["telegram", "bot", "ai", "composio", "telegraf"],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "[ \"$NODE_ENV\" = \"production\" ] && pm2 start ecosystem.config.cjs --env production || bun run src/index.ts",
    "logs": "pm2 logs",
    "logs:tail": "pm2 logs --lines 50 --nostream",
    "stop": "pm2 stop ecosystem.config.cjs && pkill -f 'bun.*--watch' 2>/dev/null; true",
    "restart": "pm2 restart ecosystem.config.cjs",
    "status": "pm2 status"
  },
  "dependencies": {
    "@composio/core": "^0.11.0",
    "@composio/openai": "^0.10.0",
    "composio-core": "^0.5.39",
    "openai": "^6.45.0",
    "pm2": "^7.0.1",
    "telegraf": "^4.16.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^6.0.3"
  }
}
